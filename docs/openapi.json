{
  "openapi": "3.1.0",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "DebtSignal API",
    "version": "1.0.0-concept",
    "summary": "Conceptual API for source-linked financing and covenant event data from SEC 8-K filings and exhibits.",
    "description": "DebtSignal is a docs-first API concept. The contract focuses on stable response envelopes, provenance, timeline metadata, explicit nulls, and machine-readable errors for financing and covenant-related events found in public SEC disclosures. This static site does not claim a live production extraction backend."
  },
  "servers": [
    {
      "url": "https://api.debtsignal.example",
      "description": "Illustrative base URL for the conceptual API"
    }
  ],
  "tags": [
    {
      "name": "Docs",
      "description": "Machine-readable contract discovery"
    },
    {
      "name": "Events",
      "description": "Financing and covenant-related event retrieval"
    },
    {
      "name": "Metadata",
      "description": "Supporting vocabulary and schema metadata"
    }
  ],
  "paths": {
    "/v1/docs/openapi.json": {
      "get": {
        "tags": [
          "Docs"
        ],
        "operationId": "getOpenApiDocument",
        "summary": "Fetch the conceptual OpenAPI document",
        "description": "Returns the machine-readable OpenAPI 3.1 contract for the docs-first DebtSignal API concept.",
        "responses": {
          "200": {
            "description": "OpenAPI document",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "OpenAPI 3.1 document for the conceptual API.",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "/v1/events": {
      "get": {
        "tags": [
          "Events"
        ],
        "operationId": "listEvents",
        "summary": "List financing and covenant-related events",
        "description": "Returns a cursor-paginated list of source-linked event records derived from SEC 8-K filings and related exhibits.",
        "parameters": [
          {
            "name": "issuer_id",
            "in": "query",
            "description": "Filter by DebtSignal issuer identifier when known.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cik",
            "in": "query",
            "description": "Filter by 10-digit SEC Central Index Key.",
            "schema": {
              "type": "string",
              "pattern": "^[0-9]{10}$"
            }
          },
          {
            "name": "ticker",
            "in": "query",
            "description": "Filter by issuer ticker symbol.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "event_type",
            "in": "query",
            "description": "Filter by one supported event classification code.",
            "schema": {
              "$ref": "#/components/schemas/EventTypeCode"
            }
          },
          {
            "name": "filed_at_gte",
            "in": "query",
            "description": "Return events with filing timestamps on or after this RFC 3339 UTC instant.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "filed_at_lte",
            "in": "query",
            "description": "Return events with filing timestamps on or before this RFC 3339 UTC instant.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "has_exhibit",
            "in": "query",
            "description": "Filter for events whose provenance includes at least one exhibit document.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Page size for list responses.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Opaque pagination cursor returned by a previous list response.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event list response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "402": {
            "$ref": "#/components/responses/PaymentRequiredReserved"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
    "/v1/events/{event_id}": {
      "get": {
        "tags": [
          "Events"
        ],
        "operationId": "getEvent",
        "summary": "Fetch one event by ID",
        "description": "Returns a single source-linked financing or covenant event record.",
        "parameters": [
          {
            "name": "event_id",
            "in": "path",
            "required": true,
            "description": "DebtSignal event identifier.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Single event response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventDetailResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "402": {
            "$ref": "#/components/responses/PaymentRequiredReserved"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    },
    "/v1/event-types": {
      "get": {
        "tags": [
          "Metadata"
        ],
        "operationId": "listEventTypes",
        "summary": "List supported event type codes",
        "description": "Returns the classification vocabulary used by the event endpoints.",
        "responses": {
          "200": {
            "description": "Event type metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventTypeListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "402": {
            "$ref": "#/components/responses/PaymentRequiredReserved"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "The request parameters are invalid for this contract.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetail"
            },
            "example": {
              "type": "https://debtsignal.example/problems/invalid-parameter",
              "title": "Invalid request parameters",
              "status": 400,
              "detail": "The `limit` parameter must be between 1 and 100.",
              "code": "invalid_parameter",
              "instance": "/v1/events?limit=500"
            }
          }
        }
      },
      "PaymentRequiredReserved": {
        "description": "Reserved for future paid access patterns. Included for forward compatibility only; not active in this docs-first launch.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetail"
            },
            "example": {
              "type": "https://debtsignal.example/problems/payment-required",
              "title": "Payment required",
              "status": 402,
              "detail": "This code is reserved for future paid access patterns and is not currently active on the static docs site.",
              "code": "payment_required_reserved",
              "future_facing": true,
              "docs_url": "https://debtsignal.example/docs/billing"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Too many requests in a short time window.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetail"
            },
            "example": {
              "type": "https://debtsignal.example/problems/rate-limited",
              "title": "Rate limited",
              "status": 429,
              "detail": "Retry after 30 seconds.",
              "code": "rate_limited",
              "retry_after_seconds": 30
            }
          }
        }
      },
      "ServiceUnavailable": {
        "description": "The service is temporarily unavailable.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetail"
            },
            "example": {
              "type": "https://debtsignal.example/problems/service-unavailable",
              "title": "Service unavailable",
              "status": 503,
              "detail": "The extraction or retrieval service is temporarily unavailable.",
              "code": "service_unavailable",
              "retry_after_seconds": 120
            }
          }
        }
      }
    },
    "schemas": {
      "EventListResponse": {
        "type": "object",
        "required": [
          "data",
          "meta",
          "page"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          },
          "page": {
            "$ref": "#/components/schemas/PageInfo"
          }
        }
      },
      "EventDetailResponse": {
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Event"
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        }
      },
      "EventTypeListResponse": {
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EventType"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/ResponseMeta"
          }
        }
      },
      "ResponseMeta": {
        "type": "object",
        "required": [
          "request_id",
          "generated_at",
          "api_version",
          "mode",
          "source_scope",
          "time_semantics"
        ],
        "properties": {
          "request_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Request identifier if generated by an implementation. Can be null in static examples."
          },
          "generated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the response object was generated."
          },
          "api_version": {
            "type": "string",
            "description": "Semantic version or concept version label."
          },
          "mode": {
            "type": "string",
            "enum": [
              "conceptual_docs_example",
              "conceptual_api_response"
            ],
            "description": "Clarifies that the current payload is conceptual, not a claim of live production extraction."
          },
          "source_scope": {
            "type": "string",
            "enum": [
              "public_sec_filings_only"
            ]
          },
          "time_semantics": {
            "$ref": "#/components/schemas/TimeSemantics"
          }
        }
      },
      "TimeSemantics": {
        "type": "object",
        "required": [
          "timestamps",
          "date_fields",
          "cursor_sort"
        ],
        "properties": {
          "timestamps": {
            "type": "string",
            "description": "Definition for timestamp fields.",
            "example": "RFC 3339 UTC"
          },
          "date_fields": {
            "type": "string",
            "description": "Definition for date-only fields.",
            "example": "Calendar dates when only a day is disclosed; null when no reliable date can be extracted."
          },
          "cursor_sort": {
            "type": "string",
            "description": "Defines the ordering used for opaque list cursors.",
            "example": "Descending by filing timestamp, then event_id"
          }
        }
      },
      "PageInfo": {
        "type": "object",
        "required": [
          "limit",
          "next_cursor",
          "has_more"
        ],
        "properties": {
          "limit": {
            "type": "integer"
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ],
            "description": "Opaque cursor for the next page. Null when there is no next page."
          },
          "has_more": {
            "type": "boolean"
          }
        }
      },
      "EventType": {
        "type": "object",
        "required": [
          "code",
          "label",
          "description"
        ],
        "properties": {
          "code": {
            "$ref": "#/components/schemas/EventTypeCode"
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "EventTypeCode": {
        "type": "string",
        "enum": [
          "new_financing",
          "amendment",
          "waiver",
          "default_or_acceleration",
          "covenant_change",
          "maturity_extension",
          "refinancing",
          "repayment_or_termination",
          "collateral_or_guarantor_change",
          "liquidity_update"
        ]
      },
      "Event": {
        "type": "object",
        "required": [
          "event_id",
          "event_type",
          "title",
          "summary",
          "issuer",
          "filing",
          "timeline",
          "terms",
          "provenance",
          "confidence",
          "completeness",
          "extraction_notes"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "description": "Durable event identifier."
          },
          "event_type": {
            "$ref": "#/components/schemas/EventTypeCode"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "issuer": {
            "$ref": "#/components/schemas/Issuer"
          },
          "filing": {
            "$ref": "#/components/schemas/Filing"
          },
          "timeline": {
            "$ref": "#/components/schemas/EventTimeline"
          },
          "terms": {
            "$ref": "#/components/schemas/EventTerms"
          },
          "provenance": {
            "$ref": "#/components/schemas/Provenance"
          },
          "confidence": {
            "$ref": "#/components/schemas/Confidence"
          },
          "completeness": {
            "$ref": "#/components/schemas/Completeness"
          },
          "extraction_notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "Issuer": {
        "type": "object",
        "required": [
          "issuer_id",
          "name",
          "ticker",
          "cik"
        ],
        "properties": {
          "issuer_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "ticker": {
            "type": [
              "string",
              "null"
            ]
          },
          "cik": {
            "type": "string",
            "pattern": "^[0-9]{10}$"
          }
        }
      },
      "Filing": {
        "type": "object",
        "required": [
          "form",
          "accession_number",
          "filed_at",
          "filing_url",
          "items"
        ],
        "properties": {
          "form": {
            "type": "string",
            "const": "8-K"
          },
          "accession_number": {
            "type": "string"
          },
          "filed_at": {
            "type": "string",
            "format": "date-time",
            "description": "EDGAR filing timestamp in UTC."
          },
          "filing_url": {
            "type": "string",
            "format": "uri"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "EventTimeline": {
        "type": "object",
        "required": [
          "filed_at",
          "announced_at",
          "effective_date",
          "effective_date_precision"
        ],
        "properties": {
          "filed_at": {
            "type": "string",
            "format": "date-time"
          },
          "announced_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "Announcement timestamp when stated explicitly in the source. Null when only a date is known."
          },
          "effective_date": {
            "type": [
              "string",
              "null"
            ],
            "format": "date",
            "description": "Date the event became effective when extractable."
          },
          "effective_date_precision": {
            "type": "string",
            "enum": [
              "day",
              "timestamp",
              "unknown"
            ]
          }
        }
      },
      "EventTerms": {
        "type": "object",
        "required": [
          "facility_type",
          "principal_amount_usd",
          "currency",
          "maturity_date_old",
          "maturity_date_new",
          "covenant_summary",
          "waiver_period_end",
          "default_status",
          "collateral_change",
          "guarantor_change"
        ],
        "properties": {
          "facility_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "principal_amount_usd": {
            "type": [
              "number",
              "null"
            ]
          },
          "currency": {
            "type": [
              "string",
              "null"
            ]
          },
          "maturity_date_old": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "maturity_date_new": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "covenant_summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "waiver_period_end": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "default_status": {
            "type": [
              "string",
              "null"
            ]
          },
          "collateral_change": {
            "type": [
              "string",
              "null"
            ]
          },
          "guarantor_change": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "Provenance": {
        "type": "object",
        "required": [
          "has_exhibits",
          "sources"
        ],
        "properties": {
          "has_exhibits": {
            "type": "boolean"
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/SourceReference"
            }
          }
        }
      },
      "SourceReference": {
        "type": "object",
        "required": [
          "source_id",
          "document_type",
          "document_label",
          "source_url",
          "excerpt"
        ],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "document_type": {
            "type": "string",
            "description": "High-level source class such as filing or exhibit."
          },
          "document_label": {
            "type": "string",
            "description": "Human-readable label such as `8-K` or `Exhibit 10.1`."
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "section_reference": {
            "type": [
              "string",
              "null"
            ]
          },
          "excerpt": {
            "type": "string"
          }
        }
      },
      "Confidence": {
        "type": "object",
        "required": [
          "event_type",
          "term_extraction",
          "overall"
        ],
        "properties": {
          "event_type": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "term_extraction": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "overall": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "Completeness": {
        "type": "object",
        "required": [
          "core_event_detected",
          "key_terms_partial",
          "manual_review_recommended"
        ],
        "properties": {
          "core_event_detected": {
            "type": "boolean"
          },
          "key_terms_partial": {
            "type": "boolean"
          },
          "manual_review_recommended": {
            "type": "boolean"
          }
        }
      },
      "ProblemDetail": {
        "type": "object",
        "required": [
          "title",
          "status",
          "detail",
          "code"
        ],
        "properties": {
          "type": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "instance": {
            "type": [
              "string",
              "null"
            ]
          },
          "docs_url": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          },
          "retry_after_seconds": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "future_facing": {
            "type": [
              "boolean",
              "null"
            ]
          }
        }
      }
    }
  }
}
